# Stripe — get these from dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...

# Where the site is hosted (no trailing slash)
DOMAIN=http://localhost:3000

# SMTP — your email provider's outgoing mail settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# Resend — get your key from resend.com > API Keys
# Must also verify the sender domain (hannahbarronoutdoors.org) in the Resend dashboard
# before using a custom "from" address on that domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@hannahbarronoutdoors.org
